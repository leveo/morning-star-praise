# ---- Core ----------------------------------------------------------------
# PostgreSQL connection. Required for Songs Library + Templates. If you
# leave the URL unset the app still runs, but those two pages show a
# "database unavailable" banner.
DATABASE_URL=postgresql://user@127.0.0.1:5432/ppt_maker

# CORS allowlist for the Vite dev server.
FRONTEND_URL=http://localhost:5173

# (prod only) Google Cloud Secret Manager fallback for secrets.
# GCP_PROJECT_ID=your-project-id

# ---- LLM routing ---------------------------------------------------------
# Set to one of: openai, anthropic, gemini, minimax, qwen, glm, ollama
# Leave empty ("") to disable that modality (translation / OCR features show
# a clear error pointing here instead of a cryptic API failure).
# Text and vision can use different providers — e.g. ollama vision + gemini text.
LLM_TEXT_PROVIDER=gemini
LLM_VISION_PROVIDER=ollama

# Optional model overrides. Blank = provider default (see README table).
# LLM_TEXT_MODEL=
# LLM_VISION_MODEL=

# ---- Provider API keys (fill only the ones you route to) -----------------
GOOGLE_API_KEY=your-gemini-key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MINIMAX_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=

# ---- Ollama (local LLM) --------------------------------------------------
# Only relevant when LLM_*_PROVIDER=ollama. Local models split into two
# categories — text (translation) and vision (OCR + image reasoning).
#
# Pull the ones you'll use:
#   ollama pull gemma4:e4b        # text default (8B, multilingual)
#   ollama pull qwen3.5:9b        # text alternative (slightly stronger CJK)
#   ollama pull qwen3-vl:8b       # vision — OCR AND reasoning
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_TEXT_MODEL=gemma4:e4b
OLLAMA_VISION_MODEL=qwen3-vl:8b

# ---- Misc ----------------------------------------------------------------
# Pexels API key is only used by backend/scripts/fetch_*_backgrounds.py
# to refresh the bundled background library. Not needed for normal use.
PEXELS_API_KEY=
