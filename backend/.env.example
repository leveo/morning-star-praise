# Worship PPT Generator - Environment Variables
# In production (Cloud Run), these are loaded from Google Secret Manager

# Google API key for Gemini Vision OCR
GOOGLE_API_KEY=your-google-api-key

# PostgreSQL database URL
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/djangobackend

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Google Cloud Project ID (for Secret Manager)
GCP_PROJECT_ID=1021441549102
